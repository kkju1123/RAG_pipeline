# --- APP SETTINGS ---
ENV=dev
LOG_LEVEL=INFO
SECRET_KEY=rag-demo-secret-key-2024-change-in-prod

# --- DATABASE ---
DATABASE_URL=postgresql+asyncpg://ragadmin:changeme@localhost:5432/rag_db

# --- CACHE ---
REDIS_URL=redis://localhost:6379/0

# --- VECTOR DB ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_collection

# --- GRAPH DB ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- S3 → MinIO 替换（关键改动）---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=rag-documents
S3_ENDPOINT_URL=http://localhost:9000

# --- RAY CLUSTER (AI Engines) ---
# In K8s, these point to internal Service DNS
# Locally, you might port-forward
# --- RAY → 直接调用（绕过Ray）---
RAY_LLM_ENDPOINT=http://localhost:8000/llm
RAY_EMBED_ENDPOINT=http://localhost:8000/embed

# --- OBSERVABILITY（关闭，本地不需要）---
OTEL_EXPORTER_OTLP_ENDPOINT=

OPENAI_API_KEY=sk-3cad8c6602994d7ab2dd552da744e9b3
OPENAI_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat